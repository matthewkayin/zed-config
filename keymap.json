// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-b": ["task::Spawn", { "task_name": "Build" }],
      "ctrl-shift-r": ["task::Spawn", { "task_name": "Clean and rebuild" }],
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Picker > Editor",
    "unbind": {
      "ctrl-h": "editor::Backspace"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-h": [
        "vim::Literal",
        [
          "ctrl-h",
          "\b"
        ]
      ]
    }
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-h": "buffer_search::DeployReplace"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft"
    }
  },
  {
    "context": "BufferSearchBar",
    "unbind": {
      "ctrl-h": "search::ToggleReplace"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-l": [
        "vim::Literal",
        [
          "ctrl-l",
          "\f"
        ]
      ]
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-l": "editor::SelectLine"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-l": "pane::SplitRight"
    }
  },
  {
    "context": "BufferSearchBar",
    "unbind": {
      "ctrl-l": "search::ToggleSelection"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w h": "workspace::ActivatePaneLeft"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-k": "workspace::ActivatePaneUp"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w k": "workspace::ActivatePaneUp"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-j": [
        "vim::Literal",
        [
          "ctrl-j",
          "\n"
        ]
      ]
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-j": "pane::SplitDown"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-j": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-j": "vim::Down"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-k": [
        "vim::Literal",
        [
          "ctrl-k",
          "\u000b"
        ]
      ]
    }
  },
  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-k": [
        "vim::PushDigraph",
        {}
      ]
    }
  },
  {
    "context": "vim_mode == replace",
    "unbind": {
      "ctrl-k": [
        "vim::PushDigraph",
        {}
      ]
    }
  },
  {
    "context": "vim_mode == waiting",
    "unbind": {
      "ctrl-k": [
        "vim::PushDigraph",
        {}
      ]
    }
  },
  {
    "context": "KeymapEditor",
    "unbind": {
      "ctrl-k": "keymap_editor::OpenCreateKeybindingModal"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-k": "pane::SplitUp"
    }
  },
  {
    "context": "RecentProjects || RecentProjects > Picker > Editor",
    "unbind": {
      "ctrl-k": "recent_projects::ToggleActionsMenu"
    }
  }
]
